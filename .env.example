# Production-required variables. The deployment will refuse to start without
# these four. All other configuration (APP_URL, CANONICAL_URL, ingestion
# knobs, search provider, port, hostname, log level, email-from address) is
# baked into src/lib/config.ts as safe internal defaults.

NODE_ENV=development

# PostgreSQL connection string. Private and deployment-specific.
DATABASE_URL=postgresql://user:password@localhost:5432/viafidei

# 32+ characters of high-entropy randomness. Used to encrypt session
# cookies and to derive the in-process cron token. Must NEVER be hardcoded.
SESSION_SECRET=change-me-to-another-long-random-value-at-least-32-characters

# Admin login credentials. ADMIN_PASSWORD must be at least 12 characters.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Optional ---

# Resend API key. When unset, transactional email (welcome, password reset,
# email verification) is skipped at the transport layer and the calling
# routes surface "email_not_configured" so the user knows delivery did not
# happen. The same key powers the admin diagnostic at /admin/email.
RESEND_API_KEY=
