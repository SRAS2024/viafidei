NODE_ENV=development
APP_URL=http://localhost:3000
CANONICAL_URL=https://viafidei.com

# --- Required ---
DATABASE_URL=postgresql://user:password@localhost:5432/viafidei

# Required in production. Must be 32+ characters of high-entropy randomness.
# Either SESSION_SECRET or JWT_ACCESS_SECRET (used as fallback) must be set.
SESSION_SECRET=change-me-to-another-long-random-value-at-least-32-characters
JWT_ACCESS_SECRET=change-me-to-a-long-random-value-at-least-32-characters
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-value-32-characters

# Required in production. ADMIN_PASSWORD must be at least 12 characters.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Observability ---
# Logger minimum level: debug | info | warn | error.
# Defaults to info in production, debug otherwise.
LOG_LEVEL=

# --- Email ---
POSTMARK_SERVER_TOKEN=
EMAIL_FROM_ADDRESS=

# --- Media ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
REDIS_URL=redis://localhost:6379

# --- Monitoring ---
SENTRY_DSN=
PLAUSIBLE_DOMAIN=viafidei.com

# --- Search ---
SEARCH_PROVIDER=postgres
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# --- Translations ---
TRANSLATION_PROVIDER=
TRANSLATION_API_KEY=
TRANSLATION_DEFAULT_SOURCE_LOCALE=en
TRANSLATION_FALLBACK_LOCALE=en

# Shared secret used to authenticate calls to /api/cron/ingest. Send via the
# Authorization: Bearer <secret> header (or X-Cron-Secret). Must be at least
# 16 characters or the endpoint will refuse all calls.
CRON_SECRET=
INTERNAL_API_TOKEN=

# --- Ingestion pipeline ---
# User-Agent sent to upstream sources during scheduled fetches.
INGESTION_USER_AGENT=ViaFideiBot/1.0 (+https://viafidei.com/bot; ingestion@viafidei.com)
# Per-request timeout for outbound HTTP fetches (milliseconds).
INGESTION_HTTP_TIMEOUT_MS=15000
# Initial status assigned to ingested items. DRAFT or REVIEW. Defaults to
# REVIEW so nothing scraped becomes live without explicit admin approval.
INGESTION_INITIAL_STATUS=REVIEW
