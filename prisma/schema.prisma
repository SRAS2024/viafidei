generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MilestoneTier {
  SACRAMENT
  SPIRITUAL
  PERSONAL
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum MediaKind {
  PHOTO
  ICON
  PAINTING
  ILLUSTRATION
  STATUE
  BOOK_COVER
  FAVICON
  OTHER
}

enum TranslationStatus {
  MACHINE
  HUMAN_REVIEWED
  LOCKED
}

enum TagKind {
  GENERAL
  LITURGICAL
  PATRONAGE
  DEVOTIONAL
  SEASONAL
  THEOLOGICAL
  REGION
}

enum CategoryScope {
  PRAYER
  SAINT
  APPARITION
  DEVOTION
  PARISH
  LITURGY
  SPIRITUAL_LIFE
}

/// Source roles describe what a source is *allowed* to do in the
/// factory pipeline. A source can discover content without being
/// allowed to publish it; it can validate without being allowed to
/// provide primary body text; and so on. The role gates which jobs
/// the worker will run for the source and which fields it may write
/// onto a built package.
///
///   primary_content_source — may originate package body fields.
///   validation_source       — may only validate fields produced by
///                             another approved source.
///   enrichment_source       — may only fill enrichment / metadata
///                             slots (Catechism references, related
///                             prayers, etc.).
///   discovery_only_source   — may surface candidate URLs only; the
///                             candidates must be validated by an
///                             approved source before they can
///                             publish.
///   rejected_source         — explicitly forbidden. The worker MUST
///                             NOT enqueue any job for this source.
model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  firstName               String
  lastName                String
  role                    Role                     @default(USER)
  emailEncrypted          String?
  nameEncrypted           String?
  emailVerifiedAt         DateTime?
  language                String                   @default("en")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  profile                 Profile?
  sessions                Session[]
  journalEntries          JournalEntry[]
  savedContent            UserSavedContent[]
  goals                   Goal[]
  milestones              Milestone[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs               AdminAuditLog[]          @relation("AuditActor")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// HMAC fingerprint of the device credential cookie that bound
  /// this session. Used to revoke every session for a banned device.
  /// Optional because pre-migration sessions did not have it.
  deviceCredentialHash String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceCredentialHash])
}

model Profile {
  id               String      @id @default(cuid())
  userId           String      @unique
  avatarMediaId    String?
  languageOverride String?
  theme            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarMedia      MediaAsset? @relation(fields: [avatarMediaId], references: [id])
}

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  goalId     String?
  title      String
  body       String
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal       Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([goalId])
}

model Goal {
  id             String              @id @default(cuid())
  userId         String
  title          String
  description    String?
  templateSlug   String?
  dueDate        DateTime?
  completedAt    DateTime?
  status         GoalStatus          @default(ACTIVE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklist      GoalChecklistItem[]
  milestone      Milestone?
  journalEntries JournalEntry[]

  @@index([userId, status])
  @@index([userId, dueDate])
}

model GoalChecklistItem {
  id          String   @id @default(cuid())
  goalId      String
  label       String
  sortOrder   Int
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, sortOrder])
}

model Milestone {
  id              String        @id @default(cuid())
  userId          String
  goalId          String?       @unique
  tier            MilestoneTier
  slug            String
  title           String
  description     String?
  contentChecksum String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal            Goal?         @relation(fields: [goalId], references: [id])

  @@unique([userId, slug])
  @@index([userId, tier])
}

/// Single saved-content table. Keyed on (userId, contentType,
/// contentSlug) so a signed-in user can save any PublishedContent row
/// uniformly. Replaces the legacy UserSavedPrayer / UserSavedSaint /
/// UserSavedApparition / UserSavedParish / UserSavedDevotion tables
/// (dropped in migration 0025_drop_legacy_system).
model UserSavedContent {
  id          String               @id @default(cuid())
  userId      String
  contentType ChecklistContentType
  contentSlug String
  createdAt   DateTime             @default(now())
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType, contentSlug])
  @@index([userId])
  @@index([contentType, contentSlug])
}

model MediaAsset {
  id              String            @id @default(cuid())
  url             String
  altText         String?
  kind            MediaKind         @default(OTHER)
  sourceUrl       String?
  sourceHost      String?
  licenseInfo     String?
  attribution     String?
  checksum        String?
  confidenceScore Float?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  entityLinks     EntityMediaLink[]
  profiles        Profile[]
}

model EntityMediaLink {
  id           String     @id @default(cuid())
  entityType   String
  entityId     String
  mediaAssetId String
  isPrimary    Boolean    @default(false)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, mediaAssetId])
  @@index([entityType, entityId])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomePage {
  id        String          @id @default(cuid())
  slug      String          @unique @default("homepage")
  title     String?
  status    ContentStatus   @default(DRAFT)
  version   Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  blocks    HomePageBlock[]
}

model HomePageBlock {
  id         String   @id @default(cuid())
  pageId     String
  blockKey   String
  blockType  String
  sortOrder  Int
  configJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  page       HomePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, blockKey])
  @@unique([pageId, sortOrder])
}

model AdminAuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  actorUsername String?
  action        String
  entityType    String
  entityId      String
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  requestId     String?
  createdAt     DateTime @default(now())
  actor         User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

/// Strict QA forensic log. Every item rejected or hard-deleted by the
/// strict content QA pipeline writes one row here so the operator can
/// see exactly what failed, which contract caught it, which fields
/// were missing, and what the source URL was. DataManagementLog
/// continues to capture run-level audit; this table is the per-item
/// strict QA record.
// DataManagementLog records every action performed by the Ingestion
// & Data Management system. The `action` column is one of: ADD,
// UPDATE, DELETE, REJECT, CLEANUP, DEDUPE, CATEGORY_FIX. The
// `contentType` is the catalog table (Prayer, Saint, ...). The
// `triggeredBy` is "automatic" (cron) or "manual" (admin-triggered).
model Tag {
  id         String      @id @default(cuid())
  slug       String      @unique
  label      String
  kind       TagKind     @default(GENERAL)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  entityTags EntityTag[]

  @@index([kind])
}

model EntityTag {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  tagId      String
  createdAt  DateTime @default(now())
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, tagId])
  @@index([entityType, entityId])
  @@index([tagId])
}

model Category {
  id          String        @id @default(cuid())
  slug        String        @unique
  label       String
  scope       CategoryScope
  sortOrder   Int           @default(0)
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([scope, sortOrder])
}

// ErrorLog captures runtime errors so they can be assembled into the
// monthly Error Report PDF that is mailed to ADMIN_EMAIL on the last
// day of every month. Rows older than ~90 days are pruned by the
// regular cleanup pass so the table cannot grow unbounded.
model ErrorLog {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now())
  // One of: "page", "api", "ingestion", "scheduler", "global", "uncaught".
  source     String
  // Short machine-readable kind (e.g. "missing_table", "db_query",
  // "uncaught_exception"). Mirrors classifyPageError().
  kind       String
  message    String
  stack      String?
  route      String?
  requestId  String?
  // Severity: "error", "warn", "critical". Critical errors also
  // trigger a Critical Failure email immediately.
  severity   String   @default("error")
  context    Json?

  @@index([occurredAt])
  @@index([severity, occurredAt])
}

// AdminNotificationState tracks the per-flow state used by the admin
// notification scheduler (last biweekly send, last monthly send, which
// threshold milestones have already been emailed for each content
// type, last archive cleanup window). One row per flow key — the
// `state` JSON blob carries the per-flow shape.
model AdminNotificationState {
  id        String   @id @default(cuid())
  flow      String   @unique
  state     Json
  updatedAt DateTime @updatedAt
}

model RateLimitBucket {
  id        String   @id @default(cuid())
  bucketKey String   @unique
  policy    String
  count     Int      @default(0)
  resetAt   DateTime
  ipAddress String?
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
  @@index([policy, resetAt])
  @@index([userId])
}

/// Durable Postgres-backed ingestion job queue. Each row is one
/// scheduled ingestion task that a worker process leases, executes,
/// and releases. The queue replaces the in-process scheduler for all
/// non-interactive ingestion work and adds retries, exponential
/// backoff, priority, leases, and stale-job recovery.
/// Per-source / per-adapter / per-content-type cursor so ingestion
/// can resume from the last successful checkpoint after a restart,
/// deploy, crash, or timeout.
/// Batch-level progress for large content types. Each batch row
/// tracks how many items were discovered, created, updated, skipped,
/// rejected, archived, deduped, and failed.
/// Every archive hard-delete writes one row here so cleanup is fully
/// auditable. Pairs with the existing DataManagementLog (which captures
/// the action) by adding the actual deletion timestamp + original
/// archive timestamp + structured context.
/// Content version history for important updates (theology, official
/// documents, saints, sacraments, doctrinal material). One row written
/// per update so an admin can see what changed and decide whether the
/// new version needs human review.
/// Per-domain rate bucket for ingestion fetches (separate from the
/// web-request rate limiter). One row per upstream domain; the worker
/// updates `lastRequestAt` and the next fetch waits at least
/// requestSpacingMs since that timestamp.
/// Per-content-type pause toggle. Distinct from per-source / per-job
/// pause: an admin can pause "all Saint ingestion across every source"
/// without disabling specific jobs one by one. The worker checks for
/// a matching row keyed by `contentType` before leasing.
model ContentTypePause {
  id            String   @id @default(cuid())
  contentType   String   @unique
  pausedAt      DateTime @default(now())
  pausedReason  String?
  actorUsername String?
  updatedAt     DateTime @updatedAt
}

/// Worker heartbeat — each running worker writes its status here every
/// ~30s. Used by the admin dashboard to show active vs stale workers
/// and by the startup-time check that warns when the queue has work
/// but no worker is alive.
model WorkerHeartbeat {
  workerId        String   @id
  startedAt       DateTime
  lastHeartbeatAt DateTime @default(now())
  processedCount  Int      @default(0)
  failedCount     Int      @default(0)
  retryCount      Int      @default(0)
  currentJobId    String?
  status          String   @default("idle")
  hostname        String?
  version         String?
  metadata        Json?

  @@index([lastHeartbeatAt])
  @@index([status])
}

/// One row per URL / feed entry / API record a discovery job finds.
/// Processing jobs consume `pending` rows and update the status as
/// they ingest, skip, reject, dedupe, or fail. Decouples discovery
/// (find what's out there) from processing (turn it into a row).
/// robots.txt cache. Each domain's robots body lives here with an
/// expiry — refetched only when the cached row is past expiresAt.
/// Per-queue-row audit trail. One row per lifecycle event so a forensic
/// reconstruction of "what happened to this job" is always possible.
/// Audit row for every source tier change.
/// Normalized source document. Every fetched page becomes one of
/// these rows. Builders read SourceDocument structures, never raw
/// HTML — this is the boundary between "what we fetched" and "what
/// the factory builds packages from". Heading/paragraph/list/table/
/// link arrays are stored as JSON so each builder can pull the
/// section it needs and stamp field provenance back to the exact
/// snippet a value came from.
/// One row per package-build attempt — success or failure. Answers
/// "why was this content not created?" on the admin dashboard.
/// Rejected content lives in RejectedContentLog (after QA);
/// build failures live here (before QA).
/// Per-source / per-content-type rolling quality stats. Used by the
/// planner to pause bad sources automatically and prioritise good
/// ones. One row per (sourceId, contentType) pair.
/// Cross-source validation evidence. Sits between the builder and
/// strict QA. A built package may pass only when every required
/// field is either:
///   1. directly sourced from an approved primary source, OR
///   2. validated by a second approved validation source, OR
///   3. filled by deterministic internal rules, OR
///   4. filled by approved enrichment with provenance.
///
/// One row per (package, field, validation source) tuple. The
/// presence of a `pass` row with high enough confidence for every
/// required field means the cross-source rule for that content type
/// is satisfied.
/// Per-day, per-source, per-content-type ingestion counters. Used by
/// the planner to enforce daily caps and by admin reports to show
/// daily ingestion volume.
/// Two-tier security event log. `Suspicious` events (warning signs)
/// trigger a Suspicious Activity email; `Breach` events (active or
/// attempted attack) trigger a Security Breach email and can issue a
/// signed ban link. Every event row is the durable audit trail the
/// monthly security report PDF reads from.
///
/// Hashing rule: only one-way HMAC fingerprints (ipAddressHash,
/// deviceCredentialHash, userAgentHash) are stored — raw IPs and
/// device credentials never land in the DB.
model SecurityEvent {
  id String @id @default(cuid())

  /// Short machine-readable identifier ("admin_password_failed",
  /// "client_tamper_burst", "csrf_violation", ...).
  eventType      String
  /// "Suspicious" or "Breach" — controls which email goes out and
  /// whether a ban link is issued.
  classification String
  /// "info" | "warning" | "error" | "critical" — used to dedupe and
  /// escalate. Suspicious events default to "warning"; Breach events
  /// default to "error" or higher.
  severity       String

  /// HMAC fingerprints — never raw values. See `src/lib/security/hash.ts`.
  ipAddressHash        String?
  deviceCredentialHash String?
  userAgentHash        String?

  /// Plaintext user-agent string is kept (no PII risk) so the admin
  /// email and the admin page can show a human-readable summary.
  userAgent String?

  /// Geo-IP fields populated best-effort by the caller. The schema
  /// stores them only when the caller already had them.
  city    String?
  region  String?
  country String?

  /// Route + HTTP method the event came in on, so the admin can see
  /// "where" the attack was happening.
  targetRoute String?
  httpMethod  String?

  /// Action the attacker tried to perform ("set publicRenderReady",
  /// "POST /api/admin/...", "submitted SQLi payload", ...).
  attemptedAction String?

  /// Account context, when the event can be attributed.
  accountId    String?
  adminAccount Boolean @default(false)

  /// Request ID written by the observability layer; correlates the
  /// event to the surrounding access log.
  requestId String?

  /// Automatic remediation taken (e.g. "session revoked", "device
  /// banned via signed link", "rate-limit applied").
  automaticActionTaken String?

  /// Operational flags so the dashboard can show what fired.
  emailSent      Boolean @default(false)
  banTokenIssued Boolean @default(false)

  createdAt DateTime @default(now())

  bannedDevices      BannedDevice[]
  adminWorkerActions AdminWorkerSecurityAction[]

  @@index([eventType])
  @@index([classification])
  @@index([severity])
  @@index([createdAt])
  @@index([ipAddressHash])
  @@index([deviceCredentialHash])
}

/// Devices banned in response to a SecurityEvent. No admin UI can
/// remove a row from this table — bans are permanent by design.
/// Middleware reads `active = true` rows on every request and blocks
/// the request before any page renders.
model BannedDevice {
  id String @id @default(cuid())

  /// Hashed device credential cookie. Hashes only — see
  /// `src/lib/security/hash.ts`.
  deviceCredentialHash String
  ipAddressHash        String?
  userAgentHash        String?

  /// First and last time we observed this device. `firstSeenAt`
  /// records when the device was first linked to the originating
  /// SecurityEvent; `lastSeenAt` updates each time a banned device
  /// re-attempts a request, which is useful for spotting persistent
  /// attackers.
  firstSeenAt DateTime
  lastSeenAt  DateTime

  /// Why the device was banned ("admin_brute_force",
  /// "csrf_violation", ...). Mirrors SecurityEvent.eventType.
  banReason String

  /// SecurityEvent that triggered the ban. Used by the admin page to
  /// surface "ban context" without duplicating event fields.
  securityEventId String?
  securityEvent   SecurityEvent? @relation(fields: [securityEventId], references: [id], onDelete: SetNull)

  /// Marker for who/what created the row. "signed_ban_link" when the
  /// admin clicks the link in a Security Breach email; "system" when
  /// automated escalation triggers the ban directly.
  createdBy String

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deviceCredentialHash])
  @@index([active])
  @@index([ipAddressHash])
  @@index([createdAt])
}

/// Durable diagnostic history. Every time the admin Diagnostics panel
/// is opened or diagnostics are run, one row per diagnostic card is
/// written here so the Developer Audit report can show the diagnostic
/// snapshots that fall inside any selected time period — not only the
/// live values.
///
/// No secrets are stored: `detailsJson` is passed through the
/// diagnostic redaction pass (see `src/lib/diagnostics/redaction.ts`)
/// before the row is written.
model DiagnosticSnapshot {
  id String @id @default(cuid())

  /// Stable diagnostic identifier ("overall", "queue", "worker", ...).
  diagnosticKey   String
  /// Human-readable card title ("Queue health", ...).
  diagnosticName  String
  /// "pass" | "warn" | "fail" | "error".
  status          String
  /// One-line summary safe for display.
  summary         String
  /// Table / module the diagnostic read from.
  dataSource      String
  /// Redacted structured payload — counts, IDs, error message.
  detailsJson     Json?
  /// Suggested operator next action, when the diagnostic produced one.
  suggestedAction String?

  createdAt DateTime @default(now())

  @@index([diagnosticKey, createdAt])
  @@index([createdAt])
  @@index([status, createdAt])
}

/// Durable admin action log. One row per important admin action or
/// sensitive admin page visit. Distinct from AdminAuditLog (which
/// records content-entity before/after values): this table records
/// the request itself — who, what route, what method, what result —
/// plus the device / IP / user-agent fingerprints and best-effort geo,
/// so the Developer Audit report can show "Admin Navigation and
/// Actions" and so suspicious-activity detection can trust a valid
/// authenticated admin.
///
/// Only one-way HMAC fingerprints are stored for device / IP /
/// user-agent — raw values never land in the DB.
model AdminActionLog {
  id String @id @default(cuid())

  adminUserId   String?
  adminUsername String

  /// Machine-readable action type ("admin_login_success",
  /// "diagnostics_run", "developer_audit_report", ...).
  actionType String
  route      String?
  method     String?
  /// "success" | "failure" | "skipped" | ...
  result     String

  /// HMAC fingerprint of the device credential cookie.
  deviceFingerprint String?
  ipHash            String?
  userAgentHash     String?

  city    String?
  region  String?
  country String?

  createdAt    DateTime @default(now())
  metadataJson Json?

  @@index([createdAt])
  @@index([actionType, createdAt])
  @@index([adminUsername, createdAt])
}

// =============================================================================
// CHECKLIST-FIRST ARCHITECTURE
// =============================================================================
// The system below replaces the legacy scraper-first pipeline. Content is
// driven by approved master checklists curated by admins. The worker only
// builds items that have been admin-approved with verified sources.
//
// Flow:
//   1. Master checklist item is created (e.g. "Saint Padre Pio").
//   2. Sources are discovered and verified against the authority registry.
//   3. Admin approves the checklist item for build.
//   4. Worker picks it up, fetches every approved source, cross-checks them,
//      builds the full content package, and runs Catholic-accuracy validators.
//   5. QA report is generated; on approval the package is published.
// =============================================================================

/// The eleven content domains the checklist system curates.
enum ChecklistContentType {
  PRAYER
  DEVOTION
  SAINT
  MARIAN_TITLE
  APPARITION
  NOVENA
  SACRAMENT
  GUIDE
  CHURCH_DOCUMENT
  LITURGICAL
  SPIRITUAL_PRACTICE
}

/// Lifecycle for every checklist item. Every transition is admin-driven
/// or worker-driven and is recorded on the item.
enum ChecklistApprovalStatus {
  DISCOVERED
  SOURCE_VERIFIED
  APPROVED_FOR_BUILD
  BUILT
  QA_PENDING
  APPROVED
  REJECTED
  PUBLISHED
  NEEDS_HUMAN_REVIEW
}

/// Authority levels for approved Catholic sources. Higher levels override
/// lower ones in the worker's cross-source reconciliation pass.
enum SourceAuthorityLevel {
  VATICAN
  CATECHISM
  LITURGICAL_BOOK
  USCCB
  DIOCESAN
  RELIGIOUS_ORDER
  TRUSTED_PUBLISHER
  ACADEMIC
  COMMUNITY
}

/// State machine for a worker build job derived from an approved checklist
/// item. Mirrors the IngestionJobQueueStatus enum but specific to the
/// checklist-driven build flow so the two queues do not collide.
enum WorkerBuildStatus {
  pending
  running
  partial
  succeeded
  failed
  retrying
  cancelled
}

/// Master checklist row. One row per concrete app item the system intends
/// to publish ("Litany of the Sacred Heart", "Saint Therese of Lisieux",
/// "Solemnity of the Immaculate Conception", ...).
model ChecklistItem {
  id                  String                  @id @default(cuid())
  contentType         ChecklistContentType
  canonicalName       String
  canonicalSlug       String                  @unique
  aliases             String[]                @default([])
  summary             String?
  approvalStatus      ChecklistApprovalStatus @default(DISCOVERED)
  priority            Int                     @default(100)
  needsHumanReview    Boolean                 @default(false)
  humanReviewReason   String?
  authorityLevelHint  SourceAuthorityLevel?
  duplicateOfId       String?
  notes               String?
  metadata            Json?
  discoveredAt        DateTime                @default(now())
  sourceVerifiedAt    DateTime?
  approvedForBuildAt  DateTime?
  builtAt             DateTime?
  qaPendingAt         DateTime?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  publishedAt         DateTime?
  rejectedReason      String?
  publishedContentRef String?
  approvedByUsername  String?
  rejectedByUsername  String?
  publishedByUsername String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  duplicateOf         ChecklistItem?          @relation("ChecklistDuplicate", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates          ChecklistItem[]         @relation("ChecklistDuplicate")
  citations           ChecklistCitation[]
  buildJobs           WorkerBuildJob[]
  qaReports           ChecklistQAReport[]
  versions            ChecklistVersion[]
  relationsFrom       ChecklistRelation[]     @relation("RelationFrom")
  relationsTo         ChecklistRelation[]     @relation("RelationTo")

  @@unique([contentType, canonicalSlug])
  @@index([contentType, approvalStatus])
  @@index([approvalStatus])
  @@index([priority])
  @@index([needsHumanReview])
  @@index([canonicalSlug])
}

/// Approved Catholic source. The worker may only fetch from sources listed
/// here. Each source has an authority level used for ranking and cross-
/// source reconciliation.
model AuthoritySource {
  id             String                 @id @default(cuid())
  name           String
  host           String                 @unique
  baseUrl        String
  authorityLevel SourceAuthorityLevel
  description    String?
  notes          String?
  isActive       Boolean                @default(true)
  contentTypes   ChecklistContentType[] @default([])
  citations      ChecklistCitation[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([authorityLevel])
  @@index([isActive])
}

/// One citation per (checklist item, source URL). Stores the URL, the
/// resolved authority level, validation notes, and a content checksum so
/// silent upstream changes can be detected.
model ChecklistCitation {
  id                String               @id @default(cuid())
  checklistItemId   String
  authoritySourceId String?
  sourceUrl         String
  sourceHost        String
  authorityLevel    SourceAuthorityLevel
  title             String?
  excerpt           String?
  contentChecksum   String?
  validated         Boolean              @default(false)
  validationNotes   String?
  validatedAt       DateTime?
  fetchedAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  checklistItem     ChecklistItem        @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  authoritySource   AuthoritySource?     @relation(fields: [authoritySourceId], references: [id], onDelete: SetNull)

  @@unique([checklistItemId, sourceUrl])
  @@index([authorityLevel])
  @@index([validated])
  @@index([sourceHost])
}

/// One build job per (checklist item, attempt). Survives restarts via the
/// pending/running/partial/succeeded/failed/retrying lifecycle.
model WorkerBuildJob {
  id              String              @id @default(cuid())
  checklistItemId String
  status          WorkerBuildStatus   @default(pending)
  attempt         Int                 @default(1)
  maxAttempts     Int                 @default(5)
  priority        Int                 @default(100)
  runAt           DateTime            @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMs      Int?
  leaseExpiresAt  DateTime?
  leasedBy        String?
  partialPayload  Json?
  resultPayload   Json?
  errorMessage    String?
  confidence      Float?
  triggeredBy     String              @default("automatic")
  actorUsername   String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  checklistItem   ChecklistItem       @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  buildLogs       WorkerBuildLog[]
  qaReports       ChecklistQAReport[]

  @@index([status, priority, runAt])
  @@index([checklistItemId, attempt])
  @@index([status, leaseExpiresAt])
}

/// Structured worker build log — one row per significant step. The worker
/// writes a row when it picks a source, extracts a field, detects a
/// duplicate, raises a warning, or finalises a confidence value. Replaces
/// the legacy ContentPackageBuildLog for the checklist-driven flow.
model WorkerBuildLog {
  id         String         @id @default(cuid())
  buildJobId String
  step       String
  level      String         @default("info")
  message    String
  fieldName  String?
  sourceUrl  String?
  warnings   String[]       @default([])
  confidence Float?
  metadata   Json?
  createdAt  DateTime       @default(now())
  buildJob   WorkerBuildJob @relation(fields: [buildJobId], references: [id], onDelete: Cascade)

  @@index([buildJobId, createdAt])
  @@index([level])
  @@index([step])
}

/// QA report generated after every worker build. Stores per-dimension
/// scores so admins can sort the dashboard by the weakest signal.
model ChecklistQAReport {
  id                  String          @id @default(cuid())
  checklistItemId     String
  buildJobId          String?
  passed              Boolean
  completenessScore   Float
  accuracyScore       Float
  sourceCoverageScore Float
  formattingScore     Float
  readabilityScore    Float
  appCompatScore      Float
  overallScore        Float
  issues              String[]        @default([])
  warnings            String[]        @default([])
  fieldsValidated     String[]        @default([])
  recommendation      String
  needsHumanReview    Boolean         @default(false)
  reviewedByUsername  String?
  reviewedAt          DateTime?
  reviewerNotes       String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  checklistItem       ChecklistItem   @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  buildJob            WorkerBuildJob? @relation(fields: [buildJobId], references: [id], onDelete: SetNull)

  @@index([checklistItemId, createdAt])
  @@index([passed])
  @@index([needsHumanReview])
  @@index([overallScore])
}

/// Snapshot of every checklist build/edit so any item can be audited and
/// rolled back. Stores the full package payload before each change.
model ChecklistVersion {
  id              String        @id @default(cuid())
  checklistItemId String
  version         Int
  payload         Json
  buildJobId      String?
  authorUsername  String?
  changeSummary   String?
  createdAt       DateTime      @default(now())
  checklistItem   ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@unique([checklistItemId, version])
  @@index([checklistItemId, createdAt])
}

/// Typed relationship between two checklist items. Examples:
///   saint --HAS_FEAST_DAY--> liturgical
///   devotion --USES_PRAYER--> prayer
///   marian_title --LINKED_TO_APPARITION--> apparition
///   guide --COVERS_SACRAMENT--> sacrament
model ChecklistRelation {
  id           String        @id @default(cuid())
  fromItemId   String
  toItemId     String
  relationType String
  notes        String?
  createdAt    DateTime      @default(now())
  fromItem     ChecklistItem @relation("RelationFrom", fields: [fromItemId], references: [id], onDelete: Cascade)
  toItem       ChecklistItem @relation("RelationTo", fields: [toItemId], references: [id], onDelete: Cascade)

  @@unique([fromItemId, toItemId, relationType])
  @@index([fromItemId])
  @@index([toItemId])
  @@index([relationType])
}

/// Published content store. The worker writes the final, QA-approved
/// package here. Public routes read from this table — never directly from
/// build logs or partial payloads. Includes a publishing gate
/// (`isPublished`) and a relation back to the source checklist item.
model PublishedContent {
  id              String               @id @default(cuid())
  checklistItemId String               @unique
  contentType     ChecklistContentType
  slug            String
  title           String
  payload         Json
  authorityLevel  SourceAuthorityLevel
  isPublished     Boolean              @default(false)
  publishedAt     DateTime?
  unpublishedAt   DateTime?
  version         Int                  @default(1)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([contentType, slug])
  @@index([contentType, isPublished])
  @@index([isPublished])
  @@index([authorityLevel])
}

// =============================================================================
// ADMIN WORKER (Phase 1)
// =============================================================================
// The Admin Worker is the autonomous website-administrator system. It is
// fully coded, deterministic, and operates without any AI APIs. Internal
// model names that already exist — ChecklistItem, WorkerBuildJob,
// WorkerBuildLog, WorkerHeartbeat — keep their existing names for code
// compatibility, and the tables below add the durable state, planning,
// learning, and reporting surfaces the Admin Worker engine needs.
//
// See `src/lib/admin-worker/` for the engine code that reads / writes
// these tables and `prisma/migrations/0024_admin_worker/migration.sql`
// for the SQL definitions.
// =============================================================================

enum AdminWorkerMode {
  SETUP
  CONSTANT_FILL
  MAINTENANCE
  REPAIR
  HOMEPAGE
  DIAGNOSTICS
  SECURITY_DEFENSE
  REPORTING
  PAUSED
}

enum AdminWorkerPriority {
  SECURITY_THREAT
  WORKER_HEALTH
  CONTENT_GOAL
  SOURCE_REPAIR
  CONTENT_BUILD
  CONTENT_VALIDATION
  CONTENT_PUBLISH
  HOMEPAGE
  DIAGNOSTICS
  CLEANUP
  MAINTENANCE
}

enum AdminWorkerPassType {
  AUTONOMOUS
  DIAGNOSTICS
  CONTENT_GOAL
  HOMEPAGE
  SOURCE_REPAIR
  SECURITY
  REPORT
  CLEANUP
}

enum AdminWorkerPassStatus {
  PENDING
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
  CANCELLED
}

enum AdminWorkerTaskType {
  DISCOVER_SOURCE
  READ_SOURCE
  CLASSIFY_CONTENT
  BUILD_CONTENT
  FORMAT_CONTENT
  VALIDATE_CONTENT
  CROSS_SOURCE_VERIFY
  PUBLISH_CONTENT
  POST_PUBLISH_VERIFY
  UPDATE_HOMEPAGE
  SECURITY_DEFENSE
  CLEANUP
  DIAGNOSTICS
  REPORT
  REPAIR
}

enum AdminWorkerTaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
  CANCELLED
}

enum AdminWorkerLogSeverity {
  DEBUG
  INFO
  WARN
  ERROR
  CRITICAL
}

enum AdminWorkerLogCategory {
  OVERVIEW
  WORKER_PASS
  SOURCE_DISCOVERY
  SOURCE_READING
  CONTENT_CLASSIFICATION
  CONTENT_BUILD
  VALIDATION
  QA
  PUBLISHING
  POST_PUBLISH
  HOMEPAGE
  CLEANUP
  SECURITY
  REPORT
  ERROR
  REPAIR
}

enum AdminWorkerMemoryType {
  SOURCE_PRIORITY
  BUILDER_PRIORITY
  CONTENT_TYPE_PRIORITY
  VALIDATION_SOURCE_PRIORITY
  HOMEPAGE_SELECTION
  CLEANUP_AGGRESSIVENESS
  FAILURE_PATTERN
  SOURCE_RETRY_TIMING
  GENERIC
}

enum SourceReputationTier {
  TRUSTED
  GOOD
  NEUTRAL
  LIMITED
  POOR
  PAUSED
}

enum CandidateSourceUrlStatus {
  DISCOVERED
  PRIORITIZED
  FETCHED
  BUILT
  REJECTED
  PAUSED
}

enum CandidateSourceDiscoveryMethod {
  CONFIGURED_URL
  SITEMAP
  RSS
  API
  SEARCH_PAGE
  INTERNAL_LINK
  DIRECTORY
  MANUAL
}

enum ContentGoalStatus {
  NOT_STARTED
  IN_PROGRESS
  NEAR_GOAL
  GOAL_MET
  MAINTENANCE
  PAUSED
}

enum HumanReviewStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  EXPIRED
}

enum HomepageWorkerDraftMode {
  AUTOMATIC_SMALL
  SEASONAL_REFRESH
  CONTENT_GAP_REPAIR
  ADMIN_REQUESTED
  FULL_REFRESH
}

enum HomepageWorkerDraftStatus {
  PROPOSED
  AUTO_PUBLISHED
  AWAITING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum AdminDeveloperReportPeriod {
  LAST_24_HOURS
  LAST_7_DAYS
  LAST_30_DAYS
}

enum AdminDeveloperReportStatus {
  PENDING
  GENERATED
  FAILED
}

enum AdminWorkerSecurityActionType {
  OBSERVE
  WARN
  RATE_LIMIT
  CHALLENGE
  BAN_DEVICE
  REVOKE_SESSION
  ESCALATE
}

enum PostPublishVerificationResult {
  PASS
  WARN
  FAIL
  PENDING
}

/// Singleton row (id = "singleton") that records the current state of
/// the Admin Worker engine. The pause toggle on the diagnostics page
/// flips `paused` here; the central loop honours it on every cycle.
model AdminWorkerState {
  id               String              @id
  currentMode      AdminWorkerMode     @default(SETUP)
  currentPriority  AdminWorkerPriority @default(WORKER_HEALTH)
  currentGoal      String?
  currentTask      String?
  lastHeartbeatAt  DateTime?
  lastSuccessfulAt DateTime?
  lastFailedAt     DateTime?
  currentBlocker   String?
  recoveryAction   String?
  workerVersion    String              @default("admin-worker/0.1")
  paused           Boolean             @default(false)
  pausedReason     String?
  pausedByUsername String?
  pausedAt         DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([lastHeartbeatAt])
  @@index([paused])
}

/// One row per Admin Worker pass. A pass is a single decide-then-act
/// cycle of the central loop; it groups all tasks, logs, decisions, and
/// homepage drafts created during that cycle.
model AdminWorkerPass {
  id                 String                @id @default(cuid())
  passType           AdminWorkerPassType
  status             AdminWorkerPassStatus @default(PENDING)
  startedAt          DateTime              @default(now())
  completedAt        DateTime?
  durationMs         Int?
  tasksPlanned       Int                   @default(0)
  tasksCompleted     Int                   @default(0)
  tasksFailed        Int                   @default(0)
  contentBuilt       Int                   @default(0)
  contentPublished   Int                   @default(0)
  contentRejected    Int                   @default(0)
  homepageActions    Int                   @default(0)
  securityActions    Int                   @default(0)
  diagnosticsResults Json?
  summary            String?
  errorMessage       String?

  tasks            AdminWorkerTask[]
  logs             AdminWorkerLog[]
  decisions        AdminWorkerDecision[]
  homepageDrafts   HomepageWorkerDraft[]
  securityActionsR AdminWorkerSecurityAction[]

  @@index([status])
  @@index([passType, startedAt])
  @@index([startedAt])
}

/// A single planned action the Admin Worker decided to take. Tasks are
/// generated by the planner from content goals, source repairs, security
/// events, or admin commands; they are consumed by mode handlers and
/// always produce at least one AdminWorkerLog row.
model AdminWorkerTask {
  id               String                @id @default(cuid())
  passId           String?
  taskType         AdminWorkerTaskType
  priority         AdminWorkerPriority   @default(CONTENT_BUILD)
  status           AdminWorkerTaskStatus @default(PENDING)
  contentType      String?
  sourceId         String?
  sourceUrl        String?
  relatedContentId String?
  plannedAction    String?
  result           String?
  failureReason    String?
  startedAt        DateTime?
  completedAt      DateTime?
  metadata         Json?
  createdAt        DateTime              @default(now())

  pass        AdminWorkerPass?      @relation(fields: [passId], references: [id], onDelete: SetNull)
  logs        AdminWorkerLog[]
  decisions   AdminWorkerDecision[]
  reviewQueue HumanReviewQueue[]

  @@index([passId])
  @@index([status])
  @@index([taskType, status])
  @@index([contentType])
}

/// Structured Admin Worker log. Distinct from WorkerBuildLog (which
/// stays scoped to individual checklist builds): this table records
/// every Admin Worker decision, navigator action, security action,
/// homepage action, repair, and report. Filterable by category in the
/// admin UI.
model AdminWorkerLog {
  id              String                 @id @default(cuid())
  passId          String?
  taskId          String?
  severity        AdminWorkerLogSeverity @default(INFO)
  category        AdminWorkerLogCategory @default(OVERVIEW)
  eventName       String
  message         String
  contentType     String?
  sourceHost      String?
  sourceUrl       String?
  relatedEntityId String?
  safeMetadata    Json?
  createdAt       DateTime               @default(now())

  pass AdminWorkerPass? @relation(fields: [passId], references: [id], onDelete: SetNull)
  task AdminWorkerTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([passId])
  @@index([taskId])
  @@index([category, createdAt])
  @@index([severity, createdAt])
  @@index([createdAt])
  @@index([contentType])
  @@index([sourceHost])
}

/// Key/value learning store the worker writes to as it observes
/// outcomes. The learning system NEVER invents facts: it only adjusts
/// priorities, retry timing, and source/content selection rates based
/// on stored outcomes (success/failure counts + a confidence score).
model AdminWorkerMemory {
  id           String                @id @default(cuid())
  memoryType   AdminWorkerMemoryType @default(GENERIC)
  memoryKey    String
  memoryValue  Json
  confidence   Float                 @default(0.5)
  successCount Int                   @default(0)
  failureCount Int                   @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([memoryType, memoryKey])
  @@index([memoryType])
  @@index([confidence])
}

/// Rolling per-(source, contentType) reputation used by the planner to
/// promote/pause sources without admin intervention. The reputation
/// tier is derived from the underlying rates and is updated by the
/// learning loop after every successful or failed build.
model AdminWorkerSourceReputation {
  id                            String               @id @default(cuid())
  sourceId                      String?
  sourceHost                    String
  sourceRole                    String?
  contentType                   String?
  discoverySuccessRate          Float                @default(0)
  fetchSuccessRate              Float                @default(0)
  contentBuildSuccessRate       Float                @default(0)
  qaPassRate                    Float                @default(0)
  validationEvidenceSuccessRate Float                @default(0)
  publicPublishRate             Float                @default(0)
  wrongContentRate              Float                @default(0)
  duplicateRate                 Float                @default(0)
  averageUsefulness             Float                @default(0)
  reputationTier                SourceReputationTier @default(NEUTRAL)
  paused                        Boolean              @default(false)
  lastScoreUpdate               DateTime             @default(now())
  createdAt                     DateTime             @default(now())
  updatedAt                     DateTime             @updatedAt

  @@unique([sourceHost, contentType])
  @@index([reputationTier])
  @@index([paused])
}

/// One row per major decision the worker made. The deterministic
/// decision engine writes the rules it evaluated, the inputs it saw,
/// the chosen action, and the fallback action so the admin can audit
/// "why did the worker do that?" without re-running the decision.
///
/// rankedAlternatives stores the full scored list of candidate actions
/// the brain considered (highest score first, including the chosen
/// action at index 0). brainExplanation is a short human-readable
/// summary the admin UI surfaces next to the chosen action; brainFailure
/// is non-null when the brain could not find any safe action.
model AdminWorkerDecision {
  id                  String   @id @default(cuid())
  passId              String?
  taskId              String?
  decisionType        String
  inputSummary        String
  rulesEvaluated      Json?
  chosenAction        String
  confidence          Float    @default(0)
  reason              String?
  fallbackAction      String?
  rankedAlternatives  Json?
  brainExplanation    String?
  brainFailure        String?
  riskScore           Float    @default(0)
  expectedResult      String?
  contentType         String?
  missionStage        String?
  createdAt           DateTime @default(now())

  pass AdminWorkerPass? @relation(fields: [passId], references: [id], onDelete: SetNull)
  task AdminWorkerTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([decisionType])
  @@index([createdAt])
  @@index([passId])
  @@index([missionStage])
}

/// Candidate URLs the web navigator has discovered (sitemap / RSS /
/// internal link / configured list). The classifier prioritises them
/// and the planner consumes the highest-confidence rows first.
model CandidateSourceUrl {
  id                   String                         @id @default(cuid())
  discoveredUrl        String                         @unique
  sourceHost           String
  sourceId             String?
  discoveryMethod      CandidateSourceDiscoveryMethod @default(INTERNAL_LINK)
  predictedContentType String?
  predictedUsefulness  Float                          @default(0)
  status               CandidateSourceUrlStatus       @default(DISCOVERED)
  fetchAttempts        Int                            @default(0)
  lastFetchedAt        DateTime?
  rejectionReason      String?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  @@index([status])
  @@index([sourceHost])
  @@index([predictedContentType])
  @@index([predictedUsefulness])
}

/// Per-content-type goal. The planner compares each goal's current
/// count to the minimum/desired targets and prioritises content types
/// with the largest gap.
model ContentGoal {
  id                String            @id @default(cuid())
  contentType       String            @unique
  minimumTarget     Int               @default(0)
  desiredTarget     Int               @default(0)
  currentValidCount Int               @default(0)
  gapCount          Int               @default(0)
  priority          Int               @default(100)
  status            ContentGoalStatus @default(NOT_STARTED)
  lastUpdatedAt     DateTime          @default(now())
  createdAt         DateTime          @default(now())

  @@index([status])
  @@index([priority])
}

/// Rare items needing human review. The Admin Worker is designed so
/// that this queue stays small — normal content publishing never lands
/// here. Items appear only when confidence is below threshold, deletion
/// is uncertain, the worker cannot determine content type, or sources
/// conflict in ways the cross-source verifier cannot reconcile.
model HumanReviewQueue {
  id                 String            @id @default(cuid())
  taskId             String?
  contentType        String?
  contentTitle       String?
  proposedAction     String
  reason             String
  confidence         Float             @default(0)
  sourceEvidence     Json?
  currentVersion     Json?
  proposedVersion    Json?
  status             HumanReviewStatus @default(PENDING)
  createdAt          DateTime          @default(now())
  reviewedAt         DateTime?
  reviewedByUsername String?
  reviewerNotes      String?

  task AdminWorkerTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([contentType])
  @@index([createdAt])
}

/// Proposed homepage redesign. The homepage designer writes a snapshot
/// of the current homepage + a snapshot of the proposed homepage and
/// either auto-publishes (small, high-confidence changes) or files the
/// draft for review (major changes).
model HomepageWorkerDraft {
  id               String                    @id @default(cuid())
  passId           String?
  mode             HomepageWorkerDraftMode   @default(AUTOMATIC_SMALL)
  currentSnapshot  Json?
  proposedSnapshot Json?
  reasonSummary    String?
  sectionsChanged  String[]                  @default([])
  confidence       Float                     @default(0)
  status           HomepageWorkerDraftStatus @default(PROPOSED)
  createdAt        DateTime                  @default(now())
  publishedAt      DateTime?

  pass AdminWorkerPass? @relation(fields: [passId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

/// Audit trail for every Developer Audit PDF generated. The
/// `includedSections` array records which report sections were in the
/// PDF (the report UI lets the admin filter), and `status` captures
/// success/failure so a stuck report job can be surfaced.
model AdminDeveloperReportLog {
  id               String                     @id @default(cuid())
  reportPeriod     AdminDeveloperReportPeriod
  generatedBy      String
  generatedAt      DateTime                   @default(now())
  fileSize         Int?
  includedSections String[]                   @default([])
  status           AdminDeveloperReportStatus @default(PENDING)
  errorMessage     String?

  @@index([generatedAt])
  @@index([status])
}

/// Defense actions the Admin Worker takes in response to a confirmed
/// security event. Distinct from SecurityEvent (which records that an
/// event happened): this table records what the worker decided to do
/// about it and why. Used by the security defender pass and surfaced
/// in the diagnostics card.
model AdminWorkerSecurityAction {
  id                    String                        @id @default(cuid())
  securityEventId       String?
  passId                String?
  actionType            AdminWorkerSecurityActionType
  deviceFingerprintHash String?
  ipHash                String?
  userAgentHash         String?
  route                 String?
  reason                String
  severity              String                        @default("warning")
  confidence            Float                         @default(0)
  actionTaken           String
  createdAt             DateTime                      @default(now())

  pass          AdminWorkerPass? @relation(fields: [passId], references: [id], onDelete: SetNull)
  securityEvent SecurityEvent?   @relation(fields: [securityEventId], references: [id], onDelete: SetNull)

  @@index([actionType])
  @@index([createdAt])
  @@index([securityEventId])
}

/// Result of post-publish verification on a piece of public content.
/// The worker runs verification after every publish to confirm public
/// page load, tab placement, search visibility, sitemap visibility,
/// and cache freshness. A failed verification triggers automatic
/// rollback (or human review if the failure is ambiguous).
model PostPublishVerification {
  id                String                        @id @default(cuid())
  contentType       String
  contentId         String
  slug              String
  publicPageCheck   PostPublishVerificationResult @default(PENDING)
  tabPlacementCheck PostPublishVerificationResult @default(PENDING)
  searchCheck       PostPublishVerificationResult @default(PENDING)
  sitemapCheck      PostPublishVerificationResult @default(PENDING)
  cacheCheck        PostPublishVerificationResult @default(PENDING)
  result            PostPublishVerificationResult @default(PENDING)
  errorMessage      String?
  createdAt         DateTime                      @default(now())

  @@index([contentType, contentId])
  @@index([result])
  @@index([createdAt])
}

/// Deterministic per-package quality score. The publishing gate
/// requires a `finalScore` at or above the configured threshold; lower
/// scores are repaired or rejected, and only ambiguous cases reach the
/// human review queue.
model ContentQualityScore {
  id                  String   @id @default(cuid())
  contentType         String
  contentId           String
  completenessScore   Float    @default(0)
  correctnessScore    Float    @default(0)
  formattingScore     Float    @default(0)
  sourceEvidenceScore Float    @default(0)
  validationScore     Float    @default(0)
  renderScore         Float    @default(0)
  finalScore          Float    @default(0)
  createdAt           DateTime @default(now())

  @@index([contentType, contentId])
  @@index([finalScore])
  @@index([createdAt])
}

/// Deterministic homepage quality score. The homepage designer runs
/// this every pass; a score below threshold triggers a redesign draft.
model HomepageQualityScore {
  id                       String   @id @default(cuid())
  contentFreshnessScore    Float    @default(0)
  sectionBalanceScore      Float    @default(0)
  visualCompletenessScore  Float    @default(0)
  linkHealthScore          Float    @default(0)
  seasonalRelevanceScore   Float    @default(0)
  emptyStateAvoidanceScore Float    @default(0)
  accessibilityScore       Float    @default(0)
  mobileReadinessScore     Float    @default(0)
  finalScore               Float    @default(0)
  createdAt                DateTime @default(now())

  @@index([finalScore])
  @@index([createdAt])
}

// =============================================================================
// ADMIN WORKER BRAIN — Phase 8 substrate
// =============================================================================
// Durable substrate for the explicit AdminWorkerBrain module:
//   - AdminWorkerSourceRead     reused-when-checksum-matches source reads
//   - AdminWorkerPipelineStage  one row per item moving through the
//                                content chain
//   - AdminWorkerRepairPlan     durable repair plans the worker
//                                retries with exponential backoff
// =============================================================================

enum AdminWorkerPipelineStageName {
  DISCOVERY
  CANDIDATE
  FETCH
  READ
  CLASSIFY
  CHECKLIST_ITEM
  CITATION
  BUILD_JOB
  BUILD_PACKAGE
  VALIDATE
  QA
  PUBLISH
  POST_PUBLISH_VERIFY
  SEARCH_INDEX
  SITEMAP
  CACHE
}

enum AdminWorkerPipelineStageStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  BLOCKED
  SKIPPED
}

enum AdminWorkerRepairKind {
  HEARTBEAT_STALE
  QUEUE_STUCK
  SOURCE_JOBS_MISSING
  CANDIDATE_URLS_MISSING
  DISCOVERY_FAILED
  FETCH_FAILED
  READ_FAILED
  CLASSIFY_FAILED
  EXTRACT_FAILED
  VALIDATION_FAILED
  QA_MISSING_FIELDS
  BUILD_REPEATED_FAILURE
  PERSIST_FAILED
  PUBLIC_DISPLAY_FAILED
  SEARCH_VISIBILITY_FAILED
  SITEMAP_VISIBILITY_FAILED
  CACHE_FAILED
  VALIDATION_EVIDENCE_MISSING
}

enum AdminWorkerRepairStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  ABANDONED
}

/// Durable extracted text per (sourceUrl, checksum). The brain reuses
/// a read when the checksum has not changed; refetches when the
/// checksum changes. Persists across worker restarts so a process
/// rotation does not throw away expensive extraction work.
model AdminWorkerSourceRead {
  id                  String   @id @default(cuid())
  sourceUrl           String
  sourceHost          String
  checksum            String
  extractedTitle      String?
  extractedText       String?
  extractedHeadings   Json?
  detectedContentType String?
  confidenceScore     Float    @default(0)
  rejectedSections    Json?
  fetchStatus         Int?
  etag                String?
  lastModifiedHeader  String?
  byteSize            Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([sourceUrl, checksum])
  @@index([sourceUrl])
  @@index([sourceHost])
  @@index([detectedContentType])
  @@index([createdAt])
}

/// One row per item moving through the content chain. The brain
/// consults this table to see where each item is stuck and what the
/// next stage should be.
model AdminWorkerPipelineStage {
  id                    String                          @id @default(cuid())
  stageName             AdminWorkerPipelineStageName
  status                AdminWorkerPipelineStageStatus  @default(PENDING)
  contentType           String?
  inputId               String?
  outputId              String?
  startedAt             DateTime?
  completedAt           DateTime?
  failureReason         String?
  repairRecommendation  String?
  confidenceScore       Float                           @default(0)
  metadata              Json?
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt

  @@index([stageName, status])
  @@index([contentType])
  @@index([status])
  @@index([createdAt])
}

/// Durable repair plans the worker executes and retries with
/// exponential backoff. Distinct from the legacy ad-hoc repair
/// helpers in `repair.ts` (which still exist for in-pass calls) —
/// this table carries plans that need to survive process restarts.
model AdminWorkerRepairPlan {
  id            String                  @id @default(cuid())
  kind          AdminWorkerRepairKind
  failedEntity  String?
  repairAction  String
  status        AdminWorkerRepairStatus @default(PENDING)
  attempts      Int                     @default(0)
  maxAttempts   Int                     @default(5)
  lastAttemptAt DateTime?
  nextAttemptAt DateTime?
  finalResult   String?
  metadata      Json?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([status])
  @@index([kind])
  @@index([nextAttemptAt])
  @@index([createdAt])
}

/// One row per fetch attempt against an approved source. Drives source
/// reputation, lets the brain decide whether to refetch (checksum
/// changed) or skip (checksum unchanged), and surfaces fetch quality
/// in the diagnostics card. Spec §6.
model AdminWorkerFetchResult {
  id                String   @id @default(cuid())
  sourceUrl         String
  sourceHost        String
  candidateUrlId    String?
  httpStatus        Int?
  contentType       String?
  contentLength     Int?
  checksum          String?
  etag              String?
  lastModifiedHeader String?
  redirectChain     String[] @default([])
  durationMs        Int?
  attempt           Int      @default(1)
  succeeded         Boolean  @default(false)
  unchanged         Boolean  @default(false)
  rejectionReason   String?
  errorClass        String?
  errorMessage      String?
  createdAt         DateTime @default(now())

  @@index([sourceUrl])
  @@index([sourceHost])
  @@index([candidateUrlId])
  @@index([succeeded])
  @@index([createdAt])
}

/// Structured blocks extracted from a source page. The source reader
/// stores both raw text and structured blocks; extractors consume
/// blocks rather than raw body text so they can ignore navigation,
/// footers, ads, and unrelated sidebars. Spec §7.
model AdminWorkerSourceBlock {
  id              String   @id @default(cuid())
  sourceReadId    String
  blockType       String
  blockOrder      Int
  text            String
  headingLevel    Int?
  confidenceScore Float    @default(0)
  isRejected      Boolean  @default(false)
  rejectionReason String?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([sourceReadId, blockOrder])
  @@index([blockType])
  @@index([isRejected])
}

/// Cross-source field verification result. The verifier checks a
/// sensitive field (saint feast day, scripture reference, apparition
/// approval status, etc.) against an approved validation source and
/// records the match / mismatch / conflict so the publishing gate can
/// require evidence before going live. Spec §11.
model AdminWorkerCrossSourceVerification {
  id                  String   @id @default(cuid())
  contentType         String
  contentId           String?
  packageChecksum     String?
  fieldName           String
  valueChecked        String
  validationSourceHost String
  validationSourceUrl  String?
  matchResult         String
  mismatchReason      String?
  confidenceScore     Float    @default(0)
  conflictReason      String?
  finalDecision       String
  createdAt           DateTime @default(now())

  @@index([contentType, contentId])
  @@index([validationSourceHost])
  @@index([matchResult])
  @@index([createdAt])
}
