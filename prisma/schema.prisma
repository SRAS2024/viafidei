generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MilestoneTier {
  SACRAMENT
  SPIRITUAL
  PERSONAL
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum MediaKind {
  PHOTO
  ICON
  PAINTING
  ILLUSTRATION
  STATUE
  BOOK_COVER
  FAVICON
  OTHER
}

enum ReviewStatus {
  PENDING
  AUTO_APPROVED
  HUMAN_REVIEWED
  REJECTED
}

enum TranslationStatus {
  MACHINE
  HUMAN_REVIEWED
  LOCKED
}

enum TagKind {
  GENERAL
  LITURGICAL
  PATRONAGE
  DEVOTIONAL
  SEASONAL
  THEOLOGICAL
  REGION
}

enum CategoryScope {
  PRAYER
  SAINT
  APPARITION
  DEVOTION
  PARISH
  LITURGY
  SPIRITUAL_LIFE
}

enum LiturgyKind {
  MASS_STRUCTURE
  LITURGICAL_YEAR
  SYMBOLISM
  MARRIAGE_RITE
  FUNERAL_RITE
  ORDINATION_RITE
  COUNCIL_TIMELINE
  GLOSSARY
  GENERAL
}

enum SpiritualLifeKind {
  ROSARY
  CONFESSION
  ADORATION
  DEVOTION
  CONSECRATION
  VOCATION
  GENERAL
}

enum ReviewDecision {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum IngestionRunStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum IngestionJobQueueStatus {
  pending
  running
  completed
  failed
  skipped
  retrying
}

enum SourceHealthState {
  active
  stale
  failing
  blocked
  exhausted
  low_quality
  paused
}

enum SourceTier {
  TIER_1
  TIER_2
  TIER_3
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  firstName               String
  lastName                String
  role                    Role                     @default(USER)
  emailEncrypted          String?
  nameEncrypted           String?
  emailVerifiedAt         DateTime?
  language                String                   @default("en")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  profile                 Profile?
  sessions                Session[]
  journalEntries          JournalEntry[]
  savedPrayers            UserSavedPrayer[]
  savedSaints             UserSavedSaint[]
  savedApparitions        UserSavedApparition[]
  savedParishes           UserSavedParish[]
  savedDevotions          UserSavedDevotion[]
  goals                   Goal[]
  milestones              Milestone[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs               AdminAuditLog[]          @relation("AuditActor")
  contentReviews          ContentReview[]          @relation("ReviewActor")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Profile {
  id               String      @id @default(cuid())
  userId           String      @unique
  avatarMediaId    String?
  languageOverride String?
  theme            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarMedia      MediaAsset? @relation(fields: [avatarMediaId], references: [id])
}

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  goalId     String?
  title      String
  body       String
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal       Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([goalId])
}

model Prayer {
  id                    String              @id @default(cuid())
  slug                  String              @unique
  defaultTitle          String
  body                  String
  officialPrayer        String?
  category              String
  categoryId            String?
  externalSourceKey     String?             @unique
  sourceHost            String?
  contentChecksum       String?
  status                ContentStatus       @default(DRAFT)
  archivedAt            DateTime?
  sourceConfidence      Float?
  formattingConfidence  Float?
  qualityScore          Float?
  theologicalReviewFlag Boolean             @default(false)
  sourceTier            Int?
  outcomeReason         String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  translations          PrayerTranslation[]
  savedByUsers          UserSavedPrayer[]
  categoryRel           Category?           @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@index([archivedAt])
}

model PrayerTranslation {
  id                String            @id @default(cuid())
  prayerId          String
  locale            String
  title             String
  body              String
  translationStatus TranslationStatus @default(MACHINE)
  translationEngine String?
  checksum          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  prayer            Prayer            @relation(fields: [prayerId], references: [id], onDelete: Cascade)

  @@unique([prayerId, locale])
}

model Saint {
  id                    String             @id @default(cuid())
  slug                  String             @unique
  canonicalName         String
  feastDay              String?
  feastMonth            Int?
  feastDayOfMonth       Int?
  patronages            String[]
  biography             String
  officialPrayer        String?
  externalSourceKey     String?            @unique
  contentChecksum       String?
  status                ContentStatus      @default(DRAFT)
  archivedAt            DateTime?
  sourceConfidence      Float?
  formattingConfidence  Float?
  qualityScore          Float?
  theologicalReviewFlag Boolean            @default(false)
  sourceTier            Int?
  outcomeReason         String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  translations          SaintTranslation[]
  savedByUsers          UserSavedSaint[]

  @@index([status])
  @@index([feastMonth, feastDayOfMonth])
  @@index([archivedAt])
}

model SaintTranslation {
  id                String            @id @default(cuid())
  saintId           String
  locale            String
  name              String
  biography         String
  officialPrayer    String?
  translationStatus TranslationStatus @default(MACHINE)
  translationEngine String?
  checksum          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  saint             Saint             @relation(fields: [saintId], references: [id], onDelete: Cascade)

  @@unique([saintId, locale])
}

model MarianApparition {
  id                    String                        @id @default(cuid())
  slug                  String                        @unique
  title                 String
  location              String?
  country               String?
  approvedStatus        String?
  summary               String
  officialPrayer        String?
  externalSourceKey     String?                       @unique
  contentChecksum       String?
  status                ContentStatus                 @default(DRAFT)
  archivedAt            DateTime?
  sourceConfidence      Float?
  formattingConfidence  Float?
  qualityScore          Float?
  theologicalReviewFlag Boolean                       @default(false)
  sourceTier            Int?
  outcomeReason         String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  translations          MarianApparitionTranslation[]
  savedByUsers          UserSavedApparition[]

  @@index([status])
  @@index([archivedAt])
}

model MarianApparitionTranslation {
  id                String            @id @default(cuid())
  apparitionId      String
  locale            String
  title             String
  summary           String
  officialPrayer    String?
  translationStatus TranslationStatus @default(MACHINE)
  translationEngine String?
  checksum          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  apparition        MarianApparition  @relation(fields: [apparitionId], references: [id], onDelete: Cascade)

  @@unique([apparitionId, locale])
}

model Parish {
  id                    String            @id @default(cuid())
  slug                  String            @unique
  name                  String
  address               String?
  city                  String?
  region                String?
  country               String?
  phone                 String?
  email                 String?
  websiteUrl            String?
  diocese               String?
  ociaUrl               String?
  latitude              Float?
  longitude             Float?
  externalSourceKey     String?
  sourceHost            String?
  contentChecksum       String?
  status                ContentStatus     @default(DRAFT)
  archivedAt            DateTime?
  sourceConfidence      Float?
  formattingConfidence  Float?
  qualityScore          Float?
  theologicalReviewFlag Boolean           @default(false)
  sourceTier            Int?
  outcomeReason         String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  savedByUsers          UserSavedParish[]

  @@unique([name, city, country])
  @@index([status])
  @@index([archivedAt])
}

model Goal {
  id             String              @id @default(cuid())
  userId         String
  title          String
  description    String?
  templateSlug   String?
  dueDate        DateTime?
  completedAt    DateTime?
  status         GoalStatus          @default(ACTIVE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklist      GoalChecklistItem[]
  milestone      Milestone?
  journalEntries JournalEntry[]

  @@index([userId, status])
  @@index([userId, dueDate])
}

model GoalChecklistItem {
  id          String   @id @default(cuid())
  goalId      String
  label       String
  sortOrder   Int
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, sortOrder])
}

model Milestone {
  id              String        @id @default(cuid())
  userId          String
  goalId          String?       @unique
  tier            MilestoneTier
  slug            String
  title           String
  description     String?
  contentChecksum String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal            Goal?         @relation(fields: [goalId], references: [id])

  @@unique([userId, slug])
  @@index([userId, tier])
}

model UserSavedPrayer {
  userId    String
  prayerId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prayer    Prayer   @relation(fields: [prayerId], references: [id], onDelete: Cascade)

  @@id([userId, prayerId])
}

model UserSavedSaint {
  userId    String
  saintId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  saint     Saint    @relation(fields: [saintId], references: [id], onDelete: Cascade)

  @@id([userId, saintId])
}

model UserSavedApparition {
  userId       String
  apparitionId String
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  apparition   MarianApparition @relation(fields: [apparitionId], references: [id], onDelete: Cascade)

  @@id([userId, apparitionId])
}

model UserSavedParish {
  userId    String
  parishId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parish    Parish   @relation(fields: [parishId], references: [id], onDelete: Cascade)

  @@id([userId, parishId])
}

model MediaAsset {
  id              String            @id @default(cuid())
  url             String
  altText         String?
  kind            MediaKind         @default(OTHER)
  sourceUrl       String?
  sourceHost      String?
  licenseInfo     String?
  attribution     String?
  checksum        String?
  reviewStatus    ReviewStatus      @default(PENDING)
  confidenceScore Float?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  entityLinks     EntityMediaLink[]
  profiles        Profile[]
}

model EntityMediaLink {
  id           String     @id @default(cuid())
  entityType   String
  entityId     String
  mediaAssetId String
  isPrimary    Boolean    @default(false)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, mediaAssetId])
  @@index([entityType, entityId])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomePage {
  id        String          @id @default(cuid())
  slug      String          @unique @default("homepage")
  title     String?
  status    ContentStatus   @default(DRAFT)
  version   Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  blocks    HomePageBlock[]
}

model HomePageBlock {
  id         String   @id @default(cuid())
  pageId     String
  blockKey   String
  blockType  String
  sortOrder  Int
  configJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  page       HomePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, blockKey])
  @@unique([pageId, sortOrder])
}

model IngestionSource {
  id                  String         @id @default(cuid())
  name                String
  host                String         @unique
  baseUrl             String
  sourceType          String
  isOfficial          Boolean        @default(false)
  isActive            Boolean        @default(true)
  rateLimitPerMin     Int?
  reliabilityScore    Float?
  lastSuccessfulSync  DateTime?
  lastFailedSync      DateTime?
  lastContentUpdateAt DateTime?
  lastHttpStatus      Int?
  lastEtag            String?
  lastModifiedHeader  String?
  tier                Int            @default(3)
  trustLabel          String?
  healthState         String         @default("active")
  consecutiveFailures Int            @default(0)
  lowQualityRatio     Float?
  pausedAt            DateTime?
  pausedReason        String?
  requestSpacingMs    Int?
  robotsRespect       Boolean        @default(true)
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  jobs                IngestionJob[]

  @@index([healthState])
  @@index([tier])
}

model IngestionJob {
  id              String            @id @default(cuid())
  sourceId        String
  jobName         String
  targetEntity    String
  schedule        String?
  isActive        Boolean           @default(true)
  pausedAt        DateTime?
  pausedReason    String?
  batchSizeLimit  Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  source          IngestionSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  runs            IngestionJobRun[]

  @@unique([sourceId, jobName])
}

model IngestionJobRun {
  id                    String       @id @default(cuid())
  jobId                 String
  startedAt             DateTime
  finishedAt            DateTime?
  status                String
  recordsSeen           Int          @default(0)
  recordsCreated        Int          @default(0)
  recordsUpdated        Int          @default(0)
  recordsSkipped        Int          @default(0)
  recordsFailed         Int          @default(0)
  recordsReviewRequired Int          @default(0)
  errorMessage          String?
  createdAt             DateTime     @default(now())
  job                   IngestionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, startedAt])
  @@index([status, startedAt])
}

model AdminAuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  actorUsername String?
  action        String
  entityType    String
  entityId      String
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  requestId     String?
  createdAt     DateTime @default(now())
  actor         User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

// DataManagementLog records every action performed by the Ingestion
// & Data Management system. The `action` column is one of: ADD,
// UPDATE, DELETE, REJECT, CLEANUP, DEDUPE, CATEGORY_FIX. The
// `contentType` is the catalog table (Prayer, Saint, ...). The
// `triggeredBy` is "automatic" (cron) or "manual" (admin-triggered).
model DataManagementLog {
  id            String   @id @default(cuid())
  action        String
  contentType   String
  contentRef    String?
  reason        String?
  triggeredBy   String   @default("automatic")
  actorUsername String?
  createdAt     DateTime @default(now())

  @@index([action, createdAt])
  @@index([contentType, createdAt])
  @@index([createdAt])
}

model Tag {
  id         String      @id @default(cuid())
  slug       String      @unique
  label      String
  kind       TagKind     @default(GENERAL)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  entityTags EntityTag[]

  @@index([kind])
}

model EntityTag {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  tagId      String
  createdAt  DateTime @default(now())
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, tagId])
  @@index([entityType, entityId])
  @@index([tagId])
}

model Category {
  id          String        @id @default(cuid())
  slug        String        @unique
  label       String
  scope       CategoryScope
  sortOrder   Int           @default(0)
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  prayers     Prayer[]

  @@index([scope, sortOrder])
}

model Devotion {
  id                    String                @id @default(cuid())
  slug                  String                @unique
  title                 String
  summary               String
  practiceText          String?
  durationMinutes       Int?
  externalSourceKey     String?               @unique
  contentChecksum       String?
  status                ContentStatus         @default(DRAFT)
  archivedAt            DateTime?
  sourceConfidence      Float?
  formattingConfidence  Float?
  qualityScore          Float?
  theologicalReviewFlag Boolean               @default(false)
  sourceTier            Int?
  outcomeReason         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  translations          DevotionTranslation[]
  savedByUsers          UserSavedDevotion[]

  @@index([status])
  @@index([archivedAt])
}

model DevotionTranslation {
  id                String            @id @default(cuid())
  devotionId        String
  locale            String
  title             String
  summary           String
  practiceText      String?
  translationStatus TranslationStatus @default(MACHINE)
  translationEngine String?
  checksum          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  devotion          Devotion          @relation(fields: [devotionId], references: [id], onDelete: Cascade)

  @@unique([devotionId, locale])
}

model UserSavedDevotion {
  userId     String
  devotionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  devotion   Devotion @relation(fields: [devotionId], references: [id], onDelete: Cascade)

  @@id([userId, devotionId])
}

model ContentReview {
  id               String         @id @default(cuid())
  entityType       String
  entityId         String
  reviewerUserId   String?
  reviewerUsername String?
  decision         ReviewDecision @default(PENDING)
  notes            String?
  createdAt        DateTime       @default(now())
  reviewer         User?          @relation("ReviewActor", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([decision, createdAt])
}

model LiturgyEntry {
  id                    String                    @id @default(cuid())
  slug                  String                    @unique
  kind                  LiturgyKind               @default(GENERAL)
  title                 String
  summary               String?
  body                  String
  externalSourceKey     String?                   @unique
  contentChecksum       String?
  status                ContentStatus             @default(DRAFT)
  archivedAt            DateTime?
  sourceConfidence      Float?
  formattingConfidence  Float?
  qualityScore          Float?
  theologicalReviewFlag Boolean                   @default(false)
  sourceTier            Int?
  outcomeReason         String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  translations          LiturgyEntryTranslation[]

  @@index([status])
  @@index([kind, status])
  @@index([archivedAt])
}

model LiturgyEntryTranslation {
  id                String            @id @default(cuid())
  entryId           String
  locale            String
  title             String
  summary           String?
  body              String
  translationStatus TranslationStatus @default(MACHINE)
  translationEngine String?
  checksum          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  entry             LiturgyEntry      @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, locale])
}

model SpiritualLifeGuide {
  id                    String                          @id @default(cuid())
  slug                  String                          @unique
  kind                  SpiritualLifeKind               @default(GENERAL)
  title                 String
  summary               String
  bodyText              String?
  steps                 Json?
  durationDays          Int?
  goalTemplateSlug      String?
  externalSourceKey     String?                         @unique
  contentChecksum       String?
  status                ContentStatus                   @default(DRAFT)
  archivedAt            DateTime?
  sourceConfidence      Float?
  formattingConfidence  Float?
  qualityScore          Float?
  theologicalReviewFlag Boolean                         @default(false)
  sourceTier            Int?
  outcomeReason         String?
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt
  translations          SpiritualLifeGuideTranslation[]

  @@index([status])
  @@index([kind, status])
  @@index([archivedAt])
}

model SpiritualLifeGuideTranslation {
  id                String             @id @default(cuid())
  guideId           String
  locale            String
  title             String
  summary           String
  bodyText          String?
  steps             Json?
  translationStatus TranslationStatus  @default(MACHINE)
  translationEngine String?
  checksum          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  guide             SpiritualLifeGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([guideId, locale])
}

model DailyLiturgy {
  id           String        @id @default(cuid())
  date         DateTime      @unique
  season       String?
  rank         String?
  feastTitle   String?
  readingsJson Json?
  saintsJson   Json?
  status       ContentStatus @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([date, status])
}

// ErrorLog captures runtime errors so they can be assembled into the
// monthly Error Report PDF that is mailed to ADMIN_EMAIL on the last
// day of every month. Rows older than ~90 days are pruned by the
// regular cleanup pass so the table cannot grow unbounded.
model ErrorLog {
  id           String   @id @default(cuid())
  occurredAt   DateTime @default(now())
  // One of: "page", "api", "ingestion", "scheduler", "global", "uncaught".
  source       String
  // Short machine-readable kind (e.g. "missing_table", "db_query",
  // "uncaught_exception"). Mirrors classifyPageError().
  kind         String
  message      String
  stack        String?
  route        String?
  requestId    String?
  // Severity: "error", "warn", "critical". Critical errors also
  // trigger a Critical Failure email immediately.
  severity     String   @default("error")
  context      Json?

  @@index([occurredAt])
  @@index([severity, occurredAt])
}

// AdminNotificationState tracks the per-flow state used by the admin
// notification scheduler (last biweekly send, last monthly send, which
// threshold milestones have already been emailed for each content
// type, last archive cleanup window). One row per flow key — the
// `state` JSON blob carries the per-flow shape.
model AdminNotificationState {
  id        String   @id @default(cuid())
  flow      String   @unique
  state     Json
  updatedAt DateTime @updatedAt
}

model RateLimitBucket {
  id        String   @id @default(cuid())
  bucketKey String   @unique
  policy    String
  count     Int      @default(0)
  resetAt   DateTime
  ipAddress String?
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
  @@index([policy, resetAt])
  @@index([userId])
}

/// Durable Postgres-backed ingestion job queue. Each row is one
/// scheduled ingestion task that a worker process leases, executes,
/// and releases. The queue replaces the in-process scheduler for all
/// non-interactive ingestion work and adds retries, exponential
/// backoff, priority, leases, and stale-job recovery.
model IngestionJobQueue {
  id              String    @id @default(cuid())
  sourceId        String?
  jobId           String?
  jobName         String
  contentType     String?
  status          String    @default("pending")
  priority        Int       @default(100)
  attempts        Int       @default(0)
  maxAttempts     Int       @default(5)
  runAt           DateTime  @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?
  leaseExpiresAt  DateTime?
  leasedBy        String?
  errorMessage    String?
  lastError       String?
  payload         Json?
  triggeredBy     String    @default("automatic")
  actorUsername   String?
  sentToReviewAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, priority, runAt])
  @@index([sourceId])
  @@index([status, leaseExpiresAt])
  @@index([jobName, status])
}

/// Per-source / per-adapter / per-content-type cursor so ingestion
/// can resume from the last successful checkpoint after a restart,
/// deploy, crash, or timeout.
model IngestionCursor {
  id             String   @id @default(cuid())
  sourceId       String?
  adapterKey     String
  contentType    String?
  cursorKey      String
  lastPosition   String?
  lastItemSlug   String?
  lastFetchedAt  DateTime?
  itemsProcessed Int      @default(0)
  completed      Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([adapterKey, cursorKey])
  @@index([sourceId])
}

/// Batch-level progress for large content types. Each batch row
/// tracks how many items were discovered, created, updated, skipped,
/// rejected, archived, deduped, and failed.
model IngestionBatch {
  id          String    @id @default(cuid())
  sourceId    String?
  adapterKey  String
  contentType String
  batchKey    String
  discovered  Int       @default(0)
  created     Int       @default(0)
  updated     Int       @default(0)
  skipped     Int       @default(0)
  rejected    Int       @default(0)
  archived    Int       @default(0)
  failed      Int       @default(0)
  deduped     Int       @default(0)
  status      String    @default("in_progress")
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  metadata    Json?

  @@index([contentType, startedAt])
  @@index([sourceId])
}

/// Every archive hard-delete writes one row here so cleanup is fully
/// auditable. Pairs with the existing DataManagementLog (which captures
/// the action) by adding the actual deletion timestamp + original
/// archive timestamp + structured context.
model ArchiveDeletionLog {
  id            String   @id @default(cuid())
  contentType   String
  contentId     String
  contentSlug   String?
  archivedAt    DateTime?
  deletedAt     DateTime @default(now())
  reason        String?
  triggeredBy   String   @default("automatic")
  actorUsername String?

  @@index([contentType, deletedAt])
  @@index([deletedAt])
}

/// Content version history for important updates (theology, official
/// documents, saints, sacraments, doctrinal material). One row written
/// per update so an admin can see what changed and decide whether the
/// new version needs human review.
model ContentVersion {
  id                String   @id @default(cuid())
  entityType        String
  entityId          String
  previousTitle     String?
  previousBody      String?
  previousChecksum  String?
  previousStatus    String?
  previousSource    String?
  previousUpdatedAt DateTime?
  changeSummary     String?
  reviewRequired    Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}

/// Per-domain rate bucket for ingestion fetches (separate from the
/// web-request rate limiter). One row per upstream domain; the worker
/// updates `lastRequestAt` and the next fetch waits at least
/// requestSpacingMs since that timestamp.
model IngestionRateBucket {
  id               String   @id @default(cuid())
  domain           String   @unique
  windowStart      DateTime @default(now())
  requestsInWindow Int      @default(0)
  lastRequestAt    DateTime?
  updatedAt        DateTime @updatedAt
}
