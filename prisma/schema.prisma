generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MilestoneTier {
  SACRAMENT
  SPIRITUAL
  PERSONAL
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum MediaKind {
  PHOTO
  ICON
  PAINTING
  ILLUSTRATION
  STATUE
  BOOK_COVER
  FAVICON
  OTHER
}

enum ReviewStatus {
  PENDING
  AUTO_APPROVED
  HUMAN_REVIEWED
  REJECTED
}

enum TranslationStatus {
  MACHINE
  HUMAN_REVIEWED
  LOCKED
}

enum TagKind {
  GENERAL
  LITURGICAL
  PATRONAGE
  DEVOTIONAL
  SEASONAL
  THEOLOGICAL
  REGION
}

enum CategoryScope {
  PRAYER
  SAINT
  APPARITION
  DEVOTION
  PARISH
  LITURGY
  SPIRITUAL_LIFE
}

enum LiturgyKind {
  MASS_STRUCTURE
  LITURGICAL_YEAR
  SYMBOLISM
  MARRIAGE_RITE
  FUNERAL_RITE
  ORDINATION_RITE
  COUNCIL_TIMELINE
  GLOSSARY
  GENERAL
}

enum SpiritualLifeKind {
  ROSARY
  CONFESSION
  ADORATION
  DEVOTION
  CONSECRATION
  VOCATION
  GENERAL
}

enum ReviewDecision {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum IngestionRunStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum IngestionJobQueueStatus {
  pending
  running
  completed
  failed
  skipped
  retrying
}

enum SourceHealthState {
  active
  stale
  failing
  blocked
  exhausted
  low_quality
  paused
}

enum SourceTier {
  TIER_1
  TIER_2
  TIER_3
}

/// Source roles describe what a source is *allowed* to do in the
/// factory pipeline. A source can discover content without being
/// allowed to publish it; it can validate without being allowed to
/// provide primary body text; and so on. The role gates which jobs
/// the worker will run for the source and which fields it may write
/// onto a built package.
///
///   primary_content_source — may originate package body fields.
///   validation_source       — may only validate fields produced by
///                             another approved source.
///   enrichment_source       — may only fill enrichment / metadata
///                             slots (Catechism references, related
///                             prayers, etc.).
///   discovery_only_source   — may surface candidate URLs only; the
///                             candidates must be validated by an
///                             approved source before they can
///                             publish.
///   rejected_source         — explicitly forbidden. The worker MUST
///                             NOT enqueue any job for this source.
enum SourceRole {
  primary_content_source
  validation_source
  enrichment_source
  discovery_only_source
  rejected_source
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  firstName               String
  lastName                String
  role                    Role                     @default(USER)
  emailEncrypted          String?
  nameEncrypted           String?
  emailVerifiedAt         DateTime?
  language                String                   @default("en")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  profile                 Profile?
  sessions                Session[]
  journalEntries          JournalEntry[]
  savedPrayers            UserSavedPrayer[]
  savedSaints             UserSavedSaint[]
  savedApparitions        UserSavedApparition[]
  savedParishes           UserSavedParish[]
  savedDevotions          UserSavedDevotion[]
  goals                   Goal[]
  milestones              Milestone[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs               AdminAuditLog[]          @relation("AuditActor")
  contentReviews          ContentReview[]          @relation("ReviewActor")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// HMAC fingerprint of the device credential cookie that bound
  /// this session. Used to revoke every session for a banned device.
  /// Optional because pre-migration sessions did not have it.
  deviceCredentialHash String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceCredentialHash])
}

model Profile {
  id               String      @id @default(cuid())
  userId           String      @unique
  avatarMediaId    String?
  languageOverride String?
  theme            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarMedia      MediaAsset? @relation(fields: [avatarMediaId], references: [id])
}

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  goalId     String?
  title      String
  body       String
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal       Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([goalId])
}

model Prayer {
  id                      String              @id @default(cuid())
  slug                    String              @unique
  defaultTitle            String
  body                    String
  officialPrayer          String?
  category                String
  categoryId              String?
  prayerType              String?
  language                String?
  externalSourceKey       String?             @unique
  sourceUrl               String?
  sourceHost              String?
  contentChecksum         String?
  status                  ContentStatus       @default(DRAFT)
  archivedAt              DateTime?
  sourceConfidence        Float?
  formattingConfidence    Float?
  qualityScore            Float?
  theologicalReviewFlag   Boolean             @default(false)
  sourceTier              Int?
  outcomeReason           String?
  packageValidationStatus String?
  packageValidationErrors String[]            @default([])
  contentPackageVersion   String?
  publicRenderReady       Boolean             @default(false)
  isThresholdEligible     Boolean             @default(false)
  lastPackageValidatedAt  DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  translations            PrayerTranslation[]
  savedByUsers            UserSavedPrayer[]
  categoryRel             Category?           @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@index([archivedAt])
  @@index([publicRenderReady])
  @@index([isThresholdEligible])
}

model PrayerTranslation {
  id                String            @id @default(cuid())
  prayerId          String
  locale            String
  title             String
  body              String
  translationStatus TranslationStatus @default(MACHINE)
  translationEngine String?
  checksum          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  prayer            Prayer            @relation(fields: [prayerId], references: [id], onDelete: Cascade)

  @@unique([prayerId, locale])
}

model Saint {
  id                      String             @id @default(cuid())
  slug                    String             @unique
  canonicalName           String
  feastDay                String?
  feastMonth              Int?
  feastDayOfMonth         Int?
  patronages              String[]
  biography               String
  saintType               String?
  officialPrayer          String?
  externalSourceKey       String?            @unique
  sourceUrl               String?
  sourceHost              String?
  contentChecksum         String?
  status                  ContentStatus      @default(DRAFT)
  archivedAt              DateTime?
  sourceConfidence        Float?
  formattingConfidence    Float?
  qualityScore            Float?
  theologicalReviewFlag   Boolean            @default(false)
  sourceTier              Int?
  outcomeReason           String?
  packageValidationStatus String?
  packageValidationErrors String[]           @default([])
  contentPackageVersion   String?
  publicRenderReady       Boolean            @default(false)
  isThresholdEligible     Boolean            @default(false)
  lastPackageValidatedAt  DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  translations            SaintTranslation[]
  savedByUsers            UserSavedSaint[]

  @@index([status])
  @@index([feastMonth, feastDayOfMonth])
  @@index([archivedAt])
  @@index([publicRenderReady])
  @@index([isThresholdEligible])
}

model SaintTranslation {
  id                String            @id @default(cuid())
  saintId           String
  locale            String
  name              String
  biography         String
  officialPrayer    String?
  translationStatus TranslationStatus @default(MACHINE)
  translationEngine String?
  checksum          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  saint             Saint             @relation(fields: [saintId], references: [id], onDelete: Cascade)

  @@unique([saintId, locale])
}

model MarianApparition {
  id                      String                        @id @default(cuid())
  slug                    String                        @unique
  title                   String
  location                String?
  country                 String?
  approvedStatus          String?
  summary                 String
  background              String?
  officialPrayer          String?
  externalSourceKey       String?                       @unique
  sourceUrl               String?
  sourceHost              String?
  contentChecksum         String?
  status                  ContentStatus                 @default(DRAFT)
  archivedAt              DateTime?
  sourceConfidence        Float?
  formattingConfidence    Float?
  qualityScore            Float?
  theologicalReviewFlag   Boolean                       @default(false)
  sourceTier              Int?
  outcomeReason           String?
  packageValidationStatus String?
  packageValidationErrors String[]                      @default([])
  contentPackageVersion   String?
  publicRenderReady       Boolean                       @default(false)
  isThresholdEligible     Boolean                       @default(false)
  lastPackageValidatedAt  DateTime?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt
  translations            MarianApparitionTranslation[]
  savedByUsers            UserSavedApparition[]

  @@index([status])
  @@index([archivedAt])
  @@index([publicRenderReady])
  @@index([isThresholdEligible])
}

model MarianApparitionTranslation {
  id                String            @id @default(cuid())
  apparitionId      String
  locale            String
  title             String
  summary           String
  officialPrayer    String?
  translationStatus TranslationStatus @default(MACHINE)
  translationEngine String?
  checksum          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  apparition        MarianApparition  @relation(fields: [apparitionId], references: [id], onDelete: Cascade)

  @@unique([apparitionId, locale])
}

model Parish {
  id                      String            @id @default(cuid())
  slug                    String            @unique
  name                    String
  address                 String?
  city                    String?
  region                  String?
  country                 String?
  phone                   String?
  email                   String?
  websiteUrl              String?
  diocese                 String?
  ociaUrl                 String?
  latitude                Float?
  longitude               Float?
  externalSourceKey       String?
  sourceUrl               String?
  sourceHost              String?
  contentChecksum         String?
  status                  ContentStatus     @default(DRAFT)
  archivedAt              DateTime?
  sourceConfidence        Float?
  formattingConfidence    Float?
  qualityScore            Float?
  theologicalReviewFlag   Boolean           @default(false)
  sourceTier              Int?
  outcomeReason           String?
  packageValidationStatus String?
  packageValidationErrors String[]          @default([])
  contentPackageVersion   String?
  publicRenderReady       Boolean           @default(false)
  isThresholdEligible     Boolean           @default(false)
  lastPackageValidatedAt  DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  savedByUsers            UserSavedParish[]

  @@unique([name, city, country])
  @@index([status])
  @@index([archivedAt])
  @@index([publicRenderReady])
  @@index([isThresholdEligible])
}

model Goal {
  id             String              @id @default(cuid())
  userId         String
  title          String
  description    String?
  templateSlug   String?
  dueDate        DateTime?
  completedAt    DateTime?
  status         GoalStatus          @default(ACTIVE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklist      GoalChecklistItem[]
  milestone      Milestone?
  journalEntries JournalEntry[]

  @@index([userId, status])
  @@index([userId, dueDate])
}

model GoalChecklistItem {
  id          String   @id @default(cuid())
  goalId      String
  label       String
  sortOrder   Int
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, sortOrder])
}

model Milestone {
  id              String        @id @default(cuid())
  userId          String
  goalId          String?       @unique
  tier            MilestoneTier
  slug            String
  title           String
  description     String?
  contentChecksum String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal            Goal?         @relation(fields: [goalId], references: [id])

  @@unique([userId, slug])
  @@index([userId, tier])
}

model UserSavedPrayer {
  userId    String
  prayerId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prayer    Prayer   @relation(fields: [prayerId], references: [id], onDelete: Cascade)

  @@id([userId, prayerId])
}

model UserSavedSaint {
  userId    String
  saintId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  saint     Saint    @relation(fields: [saintId], references: [id], onDelete: Cascade)

  @@id([userId, saintId])
}

model UserSavedApparition {
  userId       String
  apparitionId String
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  apparition   MarianApparition @relation(fields: [apparitionId], references: [id], onDelete: Cascade)

  @@id([userId, apparitionId])
}

model UserSavedParish {
  userId    String
  parishId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parish    Parish   @relation(fields: [parishId], references: [id], onDelete: Cascade)

  @@id([userId, parishId])
}

model MediaAsset {
  id              String            @id @default(cuid())
  url             String
  altText         String?
  kind            MediaKind         @default(OTHER)
  sourceUrl       String?
  sourceHost      String?
  licenseInfo     String?
  attribution     String?
  checksum        String?
  reviewStatus    ReviewStatus      @default(PENDING)
  confidenceScore Float?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  entityLinks     EntityMediaLink[]
  profiles        Profile[]
}

model EntityMediaLink {
  id           String     @id @default(cuid())
  entityType   String
  entityId     String
  mediaAssetId String
  isPrimary    Boolean    @default(false)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, mediaAssetId])
  @@index([entityType, entityId])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomePage {
  id        String          @id @default(cuid())
  slug      String          @unique @default("homepage")
  title     String?
  status    ContentStatus   @default(DRAFT)
  version   Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  blocks    HomePageBlock[]
}

model HomePageBlock {
  id         String   @id @default(cuid())
  pageId     String
  blockKey   String
  blockType  String
  sortOrder  Int
  configJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  page       HomePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, blockKey])
  @@unique([pageId, sortOrder])
}

model IngestionSource {
  id                        String         @id @default(cuid())
  name                      String
  host                      String         @unique
  baseUrl                   String
  sourceType                String
  isOfficial                Boolean        @default(false)
  isActive                  Boolean        @default(true)
  rateLimitPerMin           Int?
  reliabilityScore          Float?
  lastSuccessfulSync        DateTime?
  lastFailedSync            DateTime?
  lastContentUpdateAt       DateTime?
  lastHttpStatus            Int?
  lastEtag                  String?
  lastModifiedHeader        String?
  tier                      Int            @default(3)
  trustLabel                String?
  healthState               String         @default("active")
  consecutiveFailures       Int            @default(0)
  lowQualityRatio           Float?
  pausedAt                  DateTime?
  pausedReason              String?
  autoPaused                Boolean        @default(false)
  autoPausedAt              DateTime?
  requestSpacingMs          Int?
  robotsRespect             Boolean        @default(true)
  estimatedTotalItems       Int?
  discoveredItems           Int            @default(0)
  completedItems            Int            @default(0)
  rejectedItems             Int            @default(0)
  exhaustedAt               DateTime?
  lastSourceTierChangeAt    DateTime?
  canIngestPrayers          Boolean        @default(false)
  canIngestSaints           Boolean        @default(false)
  canIngestApparitions      Boolean        @default(false)
  canIngestParishes         Boolean        @default(false)
  canIngestDevotions        Boolean        @default(false)
  canIngestNovenas          Boolean        @default(false)
  canIngestSacraments       Boolean        @default(false)
  canIngestRosaryGuides     Boolean        @default(false)
  canIngestConsecrations    Boolean        @default(false)
  canIngestSpiritualGuides  Boolean        @default(false)
  canIngestLiturgy          Boolean        @default(false)
  canIngestHistory          Boolean        @default(false)
  canProvideScriptureText   Boolean        @default(false)
  /// Optional sitemap / feed URL that drives factory-native source
  /// discovery. When set, the worker's source_discovery handler
  /// walks this feed, records each URL as a DiscoveredSourceItem,
  /// and enqueues a source_fetch job per URL — bypassing the
  /// legacy adapter-side discovery entirely. When null, the
  /// dispatch falls back to the legacy adapter's bespoke discovery.
  discoveryFeedUrl          String?
  /// Typed discovery method the worker uses to choose HOW to
  /// discover URLs. Valid values: "sitemap", "rss", "fixed_url_list",
  /// "official_api", "factory_handler", "not_configured". Nullable
  /// until the startup setup task backfills it from
  /// discoveryFeedUrl.
  discoveryMethod           String?
  /// One-line configuration status for the admin source
  /// configuration card. e.g. "factory_native", "not_configured",
  /// "paused", "exhausted".
  configurationStatus       String?
  /// Free-text reason when the source is not configured for the
  /// factory pipeline. Surfaced on the admin source card.
  configurationStatusReason String?
  /// Per-source override for the fetch limit per discovery run.
  /// Null = use the global config default.
  fetchLimitPerRun          Int?
  /// Per-source override for the content-build limit per fetch.
  /// Null = no per-source cap.
  buildLimitPerRun          Int?
  /// Per-source daily cap on enqueued source_fetch jobs.
  /// Null = no daily cap.
  dailyCap                  Int?
  /// Factory role this source is approved for. Gates which jobs the
  /// worker enqueues and which package fields may originate here vs.
  /// be validated only. Defaults to `discovery_only_source` so a
  /// freshly added source can suggest candidates but cannot publish
  /// content until an admin promotes it. See enum SourceRole.
  role                      SourceRole     @default(discovery_only_source)
  /// Last automatic role change reason. Surfaced on the admin source
  /// card so an admin can see why a source was promoted or demoted.
  roleLastReason            String?
  /// Last automatic role change timestamp.
  roleLastChangedAt         DateTime?
  notes                     String?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  jobs                      IngestionJob[]

  @@index([healthState])
  @@index([tier])
}

model IngestionJob {
  id             String            @id @default(cuid())
  sourceId       String
  jobName        String
  targetEntity   String
  schedule       String?
  isActive       Boolean           @default(true)
  pausedAt       DateTime?
  pausedReason   String?
  batchSizeLimit Int?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  source         IngestionSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  runs           IngestionJobRun[]

  @@unique([sourceId, jobName])
}

model IngestionJobRun {
  id                    String       @id @default(cuid())
  jobId                 String
  startedAt             DateTime
  finishedAt            DateTime?
  status                String
  recordsSeen           Int          @default(0)
  recordsCreated        Int          @default(0)
  recordsUpdated        Int          @default(0)
  recordsSkipped        Int          @default(0)
  recordsFailed         Int          @default(0)
  recordsReviewRequired Int          @default(0)
  errorMessage          String?
  createdAt             DateTime     @default(now())
  job                   IngestionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, startedAt])
  @@index([status, startedAt])
}

model AdminAuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  actorUsername String?
  action        String
  entityType    String
  entityId      String
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  requestId     String?
  createdAt     DateTime @default(now())
  actor         User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

/// Strict QA forensic log. Every item rejected or hard-deleted by the
/// strict content QA pipeline writes one row here so the operator can
/// see exactly what failed, which contract caught it, which fields
/// were missing, and what the source URL was. DataManagementLog
/// continues to capture run-level audit; this table is the per-item
/// strict QA record.
model RejectedContentLog {
  id                 String   @id @default(cuid())
  contentType        String
  slug               String?
  originalTitle      String?
  sourceUrl          String?
  sourceHost         String?
  rejectionReason    String
  failedContractName String?
  failedFields       String[] @default([])
  originalChecksum   String?
  decision           String
  triggeredBy        String   @default("automatic")
  actorUsername      String?
  workerJobId        String?
  ingestionBatchId   String?
  /// Contract version the validator ran when the row was deleted.
  packageVersion     String?
  /// Final pipeline decision verbatim (delete / reject / archive / ...).
  validationDecision String?
  /// Bucket the failure falls into for the dashboard. One of
  /// "wrong_content", "missing_required_field", "source_purpose_mismatch",
  /// "format_invalid", "render_not_ready", "duplicate", "unknown".
  failureCategory    String?
  /// Cleanup mode that produced the deletion: "public_only" |
  /// "all_catalog_rows".
  cleanupMode        String?
  /// Short description of what kind of sweep triggered the deletion:
  /// "scheduled", "post_ingestion", "manual", "render_gate",
  /// "package_version_change", "catalog_revalidate".
  sweepReason        String?
  /// Status the row carried before deletion (PUBLISHED / REVIEW /
  /// DRAFT / ARCHIVED).
  originalStatus     String?
  deletedAt          DateTime @default(now())

  @@index([contentType, deletedAt])
  @@index([decision, deletedAt])
  @@index([sourceHost, deletedAt])
  @@index([deletedAt])
  @@index([workerJobId])
  @@index([ingestionBatchId])
  @@index([failureCategory, deletedAt])
  @@index([cleanupMode, deletedAt])
}

// DataManagementLog records every action performed by the Ingestion
// & Data Management system. The `action` column is one of: ADD,
// UPDATE, DELETE, REJECT, CLEANUP, DEDUPE, CATEGORY_FIX. The
// `contentType` is the catalog table (Prayer, Saint, ...). The
// `triggeredBy` is "automatic" (cron) or "manual" (admin-triggered).
model DataManagementLog {
  id            String   @id @default(cuid())
  action        String
  contentType   String
  contentRef    String?
  reason        String?
  triggeredBy   String   @default("automatic")
  actorUsername String?
